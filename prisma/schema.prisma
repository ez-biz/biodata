generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  passwordHash  String?
  googleId      String?   @unique
  image         String?
  tier          Tier      @default(FREE)
  tierExpiresAt DateTime?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  biodatas Biodata[]
  payments Payment[]
  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Biodata {
  id              String        @id @default(cuid())
  userId          String
  templateId      String
  colorScheme     String        @default("default")
  status          BiodataStatus @default(DRAFT)
  data            Json
  language        String        @default("en")
  isPaid          Boolean       @default(false)
  paidAt          DateTime?
  shareSlug       String?       @unique
  sharePassword   String?
  shareExpiresAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos  Photo[]
  payments Payment[]
  views   SharedLinkView[]

  @@index([userId])
  @@index([shareSlug])
}

model Template {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  category     String
  tier         Tier     @default(FREE)
  religions    String[]
  pages        Int      @default(1)
  photoSlots   Int      @default(1)
  colorSchemes Json
  thumbnailUrl String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
}

model Photo {
  id         String    @id @default(cuid())
  biodataId  String
  url        String
  s3Key      String
  type       PhotoType
  cropData   Json?
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())

  biodata Biodata @relation(fields: [biodataId], references: [id], onDelete: Cascade)

  @@index([biodataId])
}

model Payment {
  id                String          @id @default(cuid())
  userId            String
  biodataId         String?
  amount            Int
  currency          String          @default("INR")
  provider          PaymentProvider
  providerPaymentId String?
  status            PaymentStatus   @default(PENDING)
  plan              String
  receiptUrl        String?
  createdAt         DateTime        @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  biodata Biodata? @relation(fields: [biodataId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([providerPaymentId])
}

model SharedLinkView {
  id           String   @id @default(cuid())
  biodataId    String
  viewerIp     String?
  viewerCity   String?
  viewerDevice String?
  viewedAt     DateTime @default(now())

  biodata Biodata @relation(fields: [biodataId], references: [id], onDelete: Cascade)

  @@index([biodataId])
}

model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  discountPercent Int?
  discountAmount  Int?
  maxUses         Int?
  currentUses     Int       @default(0)
  expiresAt       DateTime?
  applicablePlans String[]
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
}

enum Tier {
  FREE
  PREMIUM
  UNLIMITED
  FAMILY
}

enum BiodataStatus {
  DRAFT
  COMPLETED
  PUBLISHED
}

enum PhotoType {
  PROFILE
  ADDITIONAL
  KUNDLI
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}
