# Database
DATABASE_URL="postgresql://user:password@localhost:5432/biodatacraft?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Razorpay (Phase 2)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# PostHog Analytics & Feature Flags
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Sentry Error Tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Supabase (Storage + Database)
# Use pooled connection (port 6543) for DATABASE_URL in production
# Use direct connection (port 5432) for DIRECT_URL (Prisma migrations)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
DIRECT_URL=""
