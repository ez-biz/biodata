# =============================================================================
# BiodataCraft Environment Variables
# =============================================================================
# Copy this file to .env.local for local development
# For Vercel: set these in Project Settings → Environment Variables
#   - Scope "Production" vars to production Supabase project
#   - Scope "Preview" vars to development Supabase project
# =============================================================================

# Database (Supabase Postgres)
# Use pooled connection (port 6543) for DATABASE_URL
# Use direct connection (port 5432) for DIRECT_URL (Prisma migrations)
DATABASE_URL="postgresql://user:password@localhost:6543/postgres?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/postgres?schema=public"

# Supabase (Storage + Auth helpers)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Razorpay Payments (optional)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Anthropic AI (optional — AI About Me feature)
ANTHROPIC_API_KEY=""

# Resend Email (optional)
RESEND_API_KEY=""

# Admin
ADMIN_EMAILS=""

# PostHog Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Sentry Error Tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
